# 复制为 .env,填真实值;.env 本身不要提交进 git。

# 必填:容器/服务器上没有交互式登录的机会,Claude Code CLI 只能靠 API key 鉴权
# (不是 claude.ai OAuth 登录那一套)。去 console.anthropic.com 生成一个 API key。
ANTHROPIC_API_KEY=

# 用 `python3 -c "import secrets; print(secrets.token_urlsafe(32))"` 生成一个足够长的随机值
REMOTE_CONTROL_TOKEN=

# 允许被远程触发的项目目录白名单,格式 key1=/abs/path/one,key2=/abs/path/two
# 客户端只能传 key,服务端才知道 key 对应哪个真实路径。
REMOTE_CONTROL_PROJECT_DIRS=research-bench=/opt/research-bench

# 以下均为可选,不填则用 server/config.py 里的默认值
REMOTE_CONTROL_MAX_CONCURRENT=2
REMOTE_CONTROL_TIMEOUT_SECONDS=1800
REMOTE_CONTROL_MAX_TURNS=40
REMOTE_CONTROL_MAX_BUDGET_USD=2.0
REMOTE_CONTROL_RATE_LIMIT_PER_MINUTE=10
REMOTE_CONTROL_DATA_DIR=/opt/remote-control/data

# ---- P2:Web Push(可选)-----------------------------------------------------
# 三个都填才启用推送(run 完成/失败/待确认时推到已订阅的浏览器);任何一个留空
# 则 push 功能整体静默关闭,其余功能不受影响。
# 生成 VAPID 密钥对(在装好 server/requirements.txt 的环境里跑):
#   python3 -c "
#   from cryptography.hazmat.primitives.asymmetric import ec
#   from cryptography.hazmat.primitives import serialization
#   from py_vapid.utils import b64urlencode
#   k = ec.generate_private_key(ec.SECP256R1())
#   print('PRIVATE:', b64urlencode(k.private_numbers().private_value.to_bytes(32, 'big')))
#   print('PUBLIC: ', b64urlencode(k.public_key().public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)))"
REMOTE_CONTROL_VAPID_PRIVATE_KEY=
REMOTE_CONTROL_VAPID_PUBLIC_KEY=
# 必须是 mailto: 或 https: 开头(推送服务用来联系你的标识)
REMOTE_CONTROL_VAPID_SUBJECT=

# ---- P2:权限确认中继(可选)-------------------------------------------------
# 灰区 Bash 命令(默认:rm -rf 变体 / git push / 包管理器 install)执行前挂起等
# 人工确认,超时默认拒绝。黑名单命中的命令永远硬拒,不进确认。
# 想关闭确认中继(回到 P1 行为)就设成空:REMOTE_CONTROL_CONFIRM_BASH_PATTERNS=
#REMOTE_CONTROL_CONFIRM_BASH_PATTERNS=
REMOTE_CONTROL_APPROVAL_TIMEOUT_SECONDS=120
#REMOTE_CONTROL_MAX_PUSH_SUBSCRIPTIONS=20

# ---- P3:research-bench 集成(可选)-----------------------------------------
# 预设命令按钮:";;" 分隔多条,每条 "标签=prompt"。前端把它们渲染成按钮,点击
# 只填充输入框(不自动提交,保留人工确认一步)。未配置则不显示。
#REMOTE_CONTROL_PRESETS=审计=/rf:audit-workflow;;工作流测试=/ef:test-workflow smoke;;恢复流水线=训练结束,请恢复流水线并分析结果
#
# 探针状态页:";;" 分隔多条,每条 "名称=/绝对路径.json"。只读白名单——只有这里
# 登记的文件可被 GET /probes 读取(与 PROJECT_DIRS 同一道防线),请求方无法指定
# 任意路径。对接 DESIGN §3.2 探针-看门狗:训练封装写的心跳/进度 JSON 在此查看。
#REMOTE_CONTROL_PROBE_FILES=train=/opt/research-bench/experiments/pipelines/foo/run-1/probe.json
#REMOTE_CONTROL_PROBE_STALE_SECONDS=300   # 心跳超过此秒数标记为陈旧(前端变色)
#REMOTE_CONTROL_PROBE_MAX_BYTES=65536     # 单个探针文件读取上限
