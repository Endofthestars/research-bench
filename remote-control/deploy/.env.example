# 复制为 .env,填真实值;.env 本身不要提交进 git。

# 必填:容器/服务器上没有交互式登录的机会,Claude Code CLI 只能靠 API key 鉴权
# (不是 claude.ai OAuth 登录那一套)。去 console.anthropic.com 生成一个 API key。
ANTHROPIC_API_KEY=

# 用 `python3 -c "import secrets; print(secrets.token_urlsafe(32))"` 生成一个足够长的随机值
REMOTE_CONTROL_TOKEN=

# 允许被远程触发的项目目录白名单,格式 key1=/abs/path/one,key2=/abs/path/two
# 客户端只能传 key,服务端才知道 key 对应哪个真实路径。
REMOTE_CONTROL_PROJECT_DIRS=research-workflow=/opt/research-workflow-plugin

# 以下均为可选,不填则用 server/config.py 里的默认值
REMOTE_CONTROL_MAX_CONCURRENT=2
REMOTE_CONTROL_TIMEOUT_SECONDS=1800
REMOTE_CONTROL_MAX_TURNS=40
REMOTE_CONTROL_MAX_BUDGET_USD=2.0
REMOTE_CONTROL_RATE_LIMIT_PER_MINUTE=10
REMOTE_CONTROL_DATA_DIR=/opt/remote-control/data
